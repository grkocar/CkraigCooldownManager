-- Robustly hides all border textures on an icon frame (child)
local _bb_childrenPool = {}
local function _bb_collectChildren(...)
    wipe(_bb_childrenPool)
    for i = 1, select("#", ...) do
        _bb_childrenPool[i] = select(i, ...)
    end
    return _bb_childrenPool
end
local function SafeGetChildren(container)
    return _bb_collectChildren(container:GetChildren())
end

-- Weak-keyed side table for per-bar-frame addon state.
-- Never write custom Lua properties directly on Blizzard pool frames (causes taint).
local _bb_barState = setmetatable({}, { __mode = "k" })
local function GetBarState(bar)
    local s = _bb_barState[bar]
    if not s then s = {} _bb_barState[bar] = s end
    return s
end

local function HideAllIconBorders(child)
    if not child then return end
    -- Try common Blizzard border names
    if child.DebuffBorder then child.DebuffBorder:SetAlpha(0) end
    if child.IconBorder then child.IconBorder:SetAlpha(0) end
    if child.Border then child.Border:SetAlpha(0) end
    -- Hide any Texture regions that look like borders
    local regions = {child:GetRegions()}
    for _, region in ipairs(regions) do
        if region and region.GetObjectType and region:GetObjectType() == "Texture" then
            local name = region.GetName and region:GetName() or ""
            if name and (name:find("Border") or name:find("border")) then
                region:SetAlpha(0)
            end
            -- Also check for typical border texture coordinates (thin, full frame)
            local l, r, t, b = region:GetTexCoord()
            if l and r and t and b and (r-l < 0.2 or b-t < 0.2) then
                region:SetAlpha(0)
            end
        end
    end
end

local function FindIconTexture(container)
    if not container then return nil end
    if container.IsObjectType and container:IsObjectType("Texture") then
        return container
    end
    local direct = container.icon or container.Icon or container.IconTexture or container.Texture
    if direct and direct.IsObjectType and direct:IsObjectType("Texture") then
        return direct
    end
    if container.GetRegions then
        for i = 1, select("#", container:GetRegions()) do
            local region = select(i, container:GetRegions())
            if region and region.IsObjectType and region:IsObjectType("Texture") then
                return region
            end
        end
    end
    if container.GetChildren then
        for _, child in ipairs({ container:GetChildren() }) do
            if child and child.GetRegions then
                for i = 1, select("#", child:GetRegions()) do
                    local region = select(i, child:GetRegions())
                    if region and region.IsObjectType and region:IsObjectType("Texture") then
                        return region
                    end
                end
            end
        end
    end
    return nil
end

-- Helper: Get profile name for current class/spec
local function GetClassSpecProfileName()
    local _, class = UnitClass("player")
    local specIndex = GetSpecialization and GetSpecialization()
    local specName = specIndex and select(2, GetSpecializationInfo(specIndex)) or "Default"
    return class .. "_" .. (specName or "Default")
end

-- Switch to the correct profile for current class/spec if it exists
local function SwitchProfileForClassSpec(db)
    if not db or not db.GetCurrentProfile then return end
    local profileName = GetClassSpecProfileName()
    if db:GetCurrentProfile() ~= profileName then
        local profiles = {}
        db:GetProfiles(profiles)
        for _, name in ipairs(profiles) do
            if name == profileName then
                db:SetProfile(profileName)
                print("[DEBUG] Profile switched to:", profileName)
                print("[DEBUG] timerTextAlign after profile switch:", db.profile and db.profile.buffBars and db.profile.buffBars.timerTextAlign)
                return
            end
        end
    end
end

-- Event frame to handle spec/profile switching
local specProfileFrame = CreateFrame("Frame")
specProfileFrame:RegisterEvent("PLAYER_ENTERING_WORLD")
specProfileFrame:RegisterEvent("PLAYER_SPECIALIZATION_CHANGED")
specProfileFrame:SetScript("OnEvent", function()
    if _G.CkraigCooldownManager and _G.CkraigCooldownManager.db then
        SwitchProfileForClassSpec(_G.CkraigCooldownManager.db)
    end
end)

